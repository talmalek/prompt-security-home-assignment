# Copy to `.env` and adjust. Loaded by pydantic-settings (see config/settings.py).
# `.env` is gitignored; never commit real secrets. In CI they come from GitHub Secrets.

# --- Prompt Security extension (required for UI tests) ---
PROMPT_SECURITY_API_KEY=<set-me>
PROMPT_SECURITY_API_DOMAIN=eu.prompt.security
# Chrome Web Store id (used only to download the .crx in scripts/fetch_extension.py)
CHROME_STORE_EXTENSION_ID=iidnankcocecmgpcafggbgbmkbcldmno
# Unpacked extension directory (created by `make extension` or automatically on first test run)
EXTENSION_PATH=extension

# --- Test / Playwright ---
TEST_BASE_URL=https://chatgpt.com/
# Extension loads in headed Chromium; CI uses xvfb-run. Locally default is headed unless:
# TEST_HEADLESS=true
TEST_BROWSER=chromium
TEST_DEFAULT_TIMEOUT=15000
TEST_SLOW_MO=0
TEST_RECORD_VIDEO=false
TEST_SCREENSHOT_ON_FAILURE=true
# TEST_BROWSER_ARGS=["--no-sandbox","--disable-setuid-sandbox","--disable-dev-shm-usage","--disable-gpu"]

# --- Notion reporter (optional) ---
# NOTION_TOKEN=ntn_************************
# NOTION_RUNS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_API_VERSION=2022-06-28
# NOTION_TIMEOUT=15.0

# --- Logging ---
LOG_LEVEL=INFO
